# ───────────────────────────────────────────────────────────────
# Checkout próprio — variáveis de ambiente (TEMPLATE — sem valores reais)
# Copie para .env.local (gitignored) e preencha. Em produção, configure no painel da Vercel.
# ───────────────────────────────────────────────────────────────

# BRPix — API PIX (https://api.brpixsolutions.com)
BRPIX_BASE_URL=https://api.brpixsolutions.com
BRPIX_PUBLIC_KEY=
BRPIX_SECRET_KEY=
# Secret do webhook (gerado no painel ao cadastrar https://cashnopixbr.site/api/webhooks/brpix)
BRPIX_WEBHOOK_SECRET=
# URL de sandbox/teste da BRPix (a confirmar com o suporte)
BRPIX_SANDBOX_BASE_URL=

# Utmify — API de pedidos (server-side)
UTMIFY_API_TOKEN=

# MongoDB (Atlas) — armazenamento dos pedidos
MONGODB_URI=
MONGODB_DB=cashnopix
