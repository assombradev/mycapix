# ───────────────────────────────────────────────────────────────
# Checkout próprio — variáveis de ambiente (TEMPLATE — sem valores reais)
# Copie para .env.local (gitignored) e preencha. Em produção, configure no painel da Vercel.
# ───────────────────────────────────────────────────────────────

# HubPague — API PIX (https://app.hubpague.io/api) — substituiu a BRPix em 08/07/2026
HUBPAGUE_BASE_URL=https://app.hubpague.io/api
# Token Bearer gerado no painel da HubPague (única credencial; o webhook NÃO tem secret —
# a validação é feita re-consultando a transação na API antes de marcar pago)
HUBPAGUE_API_TOKEN=

# Utmify — API de pedidos (server-side)
UTMIFY_API_TOKEN=
# Opcional: marca pedidos como teste na Utmify (use só em dev local; NÃO setar em produção)
UTMIFY_TEST=

# MongoDB (Atlas) — armazenamento dos pedidos
MONGODB_URI=
MONGODB_DB=cashnopix
